{
  "extends": "@parcel/config-default",
  "resolvers": [
    "./parcel-ts-resolver.js",
    "..."
  ],
  "namers": [
    "./scripts/favicon-namer.parcel.js",
    "..."
  ],
  "transformers": {
    "*.txt": [
      "@parcel/transformer-raw"
    ],
    "jsx:*.svg": [
      "...",
      "@parcel/transformer-svg-react"
    ],
    "jsx:*": [
      "..."
    ]
  }
}
